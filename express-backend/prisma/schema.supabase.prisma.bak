generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/supabase-client-v6"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DB_URL")
  directUrl = env("SUPABASE_DIRECT_URL")
  schemas   = ["public", "admin_setup"]
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  tableName String
  recordId  String
  action    String
  oldValues Json?
  newValues Json?
  userId    String?
  userEmail String?
  ipAddress String?
  timestamp DateTime @default(now())
  details   Json?

  @@index([tableName, recordId])
  @@index([timestamp])
  @@schema("public")
}

model Item {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@schema("public")
}

model TestTask {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  description String?
  status      String    @default("pending")
  priority    String    @default("medium")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@schema("public")
}

/// A comprehensive user profile model that mirrors auth.users
/// This table is managed via triggers from Supabase Auth
model User {
  id               String     @id @db.Uuid
  email            String     @unique
  username         String?    @unique
  displayName      String?    @map("display_name")
  avatarUrl        String?    @map("avatar_url")
  bio              String?
  role             String     @default("user")
  municipalityCode String?    @map("municipality_code")
  fullName         String?    @map("full_name")
  contactNo        String?    @map("contact_no")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  lastLoginAt      DateTime?  @map("last_login_at")
  userRoles        UserRole[]

  @@map("users")
  @@schema("public")
}

/// RBAC schema matches the live Supabase tables defined in
/// LocalGovernmentUnit/supabase/migrations/005_public_rbac_tables.sql
/// (kept here only to expose them to Prisma; do not generate migrations
/// from these models -- they are managed by the Supabase migrations folder).

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  roleCode    String?          @map("role_code")
  roleName    String?          @map("role_name")
  createdAt   DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  userRoles   UserRole[]
  permissions RolePermission[]

  @@map("roles")
  @@schema("admin_setup")
}

model Module {
  id          String           @id @default(uuid()) @db.Uuid
  moduleName  String?          @map("module_name")
  routePath   String?          @unique @map("route_path")
  icons       String?
  isActive    Boolean?         @default(true) @map("is_active")
  filePath    String?          @map("file_path")
  category    String?
  createdAt   DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  permissions RolePermission[]

  @@map("modules")
  @@schema("admin_setup")
}

model RolePermission {
  id        String    @id @default(uuid()) @db.Uuid
  roleId    String?   @map("role_id") @db.Uuid
  moduleId  String?   @map("module_id") @db.Uuid
  canSelect Boolean   @default(false) @map("can_select")
  canInsert Boolean   @default(false) @map("can_insert")
  canUpdate Boolean   @default(false) @map("can_update")
  canDelete Boolean   @default(false) @map("can_delete")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  role      Role?     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module    Module?   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId], map: "unique_role_module")
  @@index([roleId], map: "idx_role_permissions_role_id")
  @@index([moduleId], map: "idx_role_permissions_module_id")
  @@map("role_permissions")
  @@schema("admin_setup")
}

/// Note: user_roles.user_id references auth.users(id) in the live DB, not
/// the public.users mirror. Prisma cannot model the auth schema directly, so
/// we keep the relation to User as an application-level convention; the FK
/// in the database is enforced against auth.users.
model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  roleId    String?   @map("role_id") @db.Uuid
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  role      Role?     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId], map: "unique_user_role")
  @@index([userId], map: "idx_user_roles_user_id")
  @@index([roleId], map: "idx_user_roles_role_id")
  @@map("user_roles")
  @@schema("admin_setup")
}

model PendingUser {
  id          String    @id @default(uuid()) @db.Uuid
  email       String?   @unique @db.VarChar
  username    String?   @db.VarChar
  isConfirmed Boolean?  @default(false) @map("is_confirmed")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("pending_users")
  @@schema("admin_setup")
}

model Facility {
  id             String         @id @default(uuid()) @db.Uuid
  facilityName   String?        @map("facility_name")
  isActive       Boolean?       @default(true) @map("is_active")
  createdAt      DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  userFacilities UserFacility[]

  @@map("facilities")
  @@schema("admin_setup")
}

model UserFacility {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  facilitiesId String?   @map("facilities_id") @db.Uuid
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  facility     Facility? @relation(fields: [facilitiesId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_user_facilities_user_id")
  @@index([facilitiesId], map: "idx_user_facilities_facilities_id")
  @@map("user_facilities")
  @@schema("admin_setup")
}

model SetupSignatory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(200)
  title       String    @db.VarChar(200)
  department  String    @db.VarChar(200)
  email       String?   @db.VarChar(254)
  phone       String?   @db.VarChar(50)
  isActive    Boolean   @default(true) @map("is_active")
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Reverse relations for templates
  appraisedTemplates          SetupSignatoryTemplate[] @relation("AppraisedBy")
  assessedTemplates           SetupSignatoryTemplate[] @relation("AssessedBy")
  recommendingTemplates       SetupSignatoryTemplate[] @relation("RecommendingBy")
  approvedTemplates           SetupSignatoryTemplate[] @relation("ApprovedBy")
  provincialAssessorTemplates SetupSignatoryTemplate[] @relation("ProvincialAssessor")
  cityAssessorTemplates       SetupSignatoryTemplate[] @relation("CityAssessor")
  deputyTemplates             SetupSignatoryTemplate[] @relation("Deputy")

  @@index([deletedAt])
  @@index([department])
  @@index([title])
  @@index([name])
  @@index([isActive])
  @@map("setup_signatories")
  @@schema("public")
}

model SetupSignatoryTemplate {
  id          String  @id @default(uuid()) @db.Uuid
  year        Int
  description String?
  isActive    Boolean @default(true) @map("is_active")

  appraisedById String?   @map("appraised_by_id") @db.Uuid
  appraisedSgd  Boolean?  @default(false) @map("appraised_sgd")
  appraisedTpd  Boolean?  @default(false) @map("appraised_tpd")
  appraisedDate DateTime? @map("appraised_date") @db.Date

  assessedById String?   @map("assessed_by_id") @db.Uuid
  assessedSgd  Boolean?  @default(false) @map("assessed_sgd")
  assessedTpd  Boolean?  @default(false) @map("assessed_tpd")
  assessedDate DateTime? @map("assessed_date") @db.Date

  recommendingById String?   @map("recommending_by_id") @db.Uuid
  recommendingSgd  Boolean?  @default(false) @map("recommending_sgd")
  recommendingTpd  Boolean?  @default(false) @map("recommending_tpd")
  recommendingDate DateTime? @map("recommending_date") @db.Date

  approvedById String?   @map("approved_by_id") @db.Uuid
  approvedSgd  Boolean?  @default(false) @map("approved_sgd")
  approvedTpd  Boolean?  @default(false) @map("approved_tpd")
  approvedDate DateTime? @map("approved_date") @db.Date

  provincialAssessorId   String?   @map("provincial_assessor_id") @db.Uuid
  provincialAssessorSgd  Boolean?  @default(false) @map("provincial_assessor_sgd")
  provincialAssessorTpd  Boolean?  @default(false) @map("provincial_assessor_tpd")
  provincialAssessorDate DateTime? @map("provincial_assessor_date") @db.Date

  cityAssessorId   String?   @map("city_assessor_id") @db.Uuid
  cityAssessorSgd  Boolean?  @default(false) @map("city_assessor_sgd")
  cityAssessorTpd  Boolean?  @default(false) @map("city_assessor_tpd")
  cityAssessorDate DateTime? @map("city_assessor_date") @db.Date

  deputyId   String?   @map("deputy_id") @db.Uuid
  deputySgd  Boolean?  @default(false) @map("deputy_sgd")
  deputyTpd  Boolean?  @default(false) @map("deputy_tpd")
  deputyDate DateTime? @map("deputy_date") @db.Date

  // Relations
  appraisedBy        SetupSignatory? @relation("AppraisedBy", fields: [appraisedById], references: [id])
  assessedBy         SetupSignatory? @relation("AssessedBy", fields: [assessedById], references: [id])
  recommendingBy     SetupSignatory? @relation("RecommendingBy", fields: [recommendingById], references: [id])
  approvedBy         SetupSignatory? @relation("ApprovedBy", fields: [approvedById], references: [id])
  provincialAssessor SetupSignatory? @relation("ProvincialAssessor", fields: [provincialAssessorId], references: [id])
  cityAssessor       SetupSignatory? @relation("CityAssessor", fields: [cityAssessorId], references: [id])
  deputy             SetupSignatory? @relation("Deputy", fields: [deputyId], references: [id])

  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  deletedById String?   @map("deleted_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@unique([year, deletedAt]) // Allow multiple years if one is deleted, but active unique year
  @@map("setup_signatory_templates")
  @@schema("public")
}

model BuildingType {
  id           String                @id @default(uuid())
  code         String                @unique
  name         String
  description  String?
  createdAt    DateTime              @default(now()) @map("created_at")
  marketValues BuildingMarketValue[]

  @@map("building_types")
  @@schema("public")
}

model BuildingMarketValue {
  id              String       @id @default(uuid())
  ordinanceNo     String       @map("ordinance_no")
  ordinanceDate   DateTime?    @map("ordinance_date") @db.Date
  effectivityDate DateTime     @map("effectivity_date") @db.Date
  buildingTypeId  String       @map("building_type_id")
  structureClass  String       @map("structure_class")
  subClass        String?      @map("sub_class")
  unitValue       Decimal      @map("unit_value") @db.Decimal(12, 2)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  buildingType    BuildingType @relation(fields: [buildingTypeId], references: [id])

  @@map("building_market_values")
  @@schema("public")
}

model OrderOfPayment {
  id           String   @id @default(uuid()) @db.Uuid
  orderNumber  String   @unique @map("order_number")
  createdBy    String   @map("created_by") @db.Uuid
  amount       Decimal  @db.Decimal(12, 2)
  description  String?
  status       String   @default("pending")
  dateCreated  DateTime @default(now()) @map("date_created")
  dateModified DateTime @updatedAt @map("date_modified")
  propertyIds  Json     @default("[]") @map("property_ids")

  history OopHistory[]

  @@index([status])
  @@index([dateCreated])
  @@map("orders_of_payment")
  @@schema("public")
}

model OopHistory {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  action      String
  performedBy String   @map("performed_by") @db.Uuid
  payload     Json
  timestamp   DateTime @default(now())

  order OrderOfPayment @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, timestamp])
  @@index([action])
  @@map("oop_history")
  @@schema("public")
}

model Municipality {
  id           Int               @id @default(autoincrement())
  code         String            @unique @db.VarChar(50)
  name         String            @db.VarChar(100)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  marketValues LandMarketValue[]

  @@map("municipalities")
  @@schema("public")
}

model LandClassification {
  id         Int            @id @default(autoincrement())
  code       String         @unique @db.VarChar(20)
  name       String         @db.VarChar(100)
  category   String         @db.VarChar(50)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  subClasses LandSubClass[]

  @@map("land_classifications")
  @@schema("public")
}

model LandSubClass {
  id               Int                @id @default(autoincrement())
  classificationId Int                @map("classification_id")
  code             String             @db.VarChar(20)
  name             String?            @db.VarChar(100)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  marketValues     LandMarketValue[]
  classification   LandClassification @relation(fields: [classificationId], references: [id])

  @@unique([classificationId, code])
  @@map("land_sub_classes")
  @@schema("public")
}

model LandMarketValue {
  id              Int          @id @default(autoincrement())
  municipalityId  Int          @map("municipality_id")
  subClassId      Int          @map("sub_class_id")
  classLevel      String       @db.VarChar(20)
  rate            Decimal      @db.Decimal(12, 2)
  unit            String       @default("SQM") @db.VarChar(20)
  ordinanceNo     String       @map("ordinance_no") @db.VarChar(50)
  effectivityDate DateTime     @map("effectivity_date") @db.Date
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  municipality    Municipality @relation(fields: [municipalityId], references: [id])
  subClass        LandSubClass @relation(fields: [subClassId], references: [id])

  @@index([municipalityId])
  @@index([subClassId])
  @@index([ordinanceNo])
  @@index([effectivityDate])
  @@map("land_market_values")
  @@schema("public")
}

model SimpleLandMarketValue {
  id              String    @id @default(uuid())
  municipality    String
  classification  String
  subClass        String?   @map("sub_class")
  firstClass      Decimal?  @map("first_class") @db.Decimal(12, 2)
  secondClass     Decimal?  @map("second_class") @db.Decimal(12, 2)
  thirdClass      Decimal?  @map("third_class") @db.Decimal(12, 2)
  fourthClass     Decimal?  @map("fourth_class") @db.Decimal(12, 2)
  unit            String    @default("SQM")
  ordinanceNo     String    @default("716-2024") @map("ordinance_no")
  ordinanceDate   DateTime? @map("ordinance_date") @db.Date
  effectivityYear Int       @default(2025) @map("effectivity_year")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("simple_land_market_values")
  @@schema("public")
}

model Land_Agricultural {
  id              Int      @id @default(autoincrement())
  landType        String   @map("land_type") @db.VarChar(100)
  classLevel      String?  @map("class_level") @db.VarChar(20) // Nullable for Unclassified
  unitValue       Decimal  @map("unit_value") @db.Decimal(12, 2)
  ordinanceNo     String   @default("716-2024") @map("ordinance_no") @db.VarChar(50)
  effectivityDate DateTime @map("effectivity_date") @db.Date
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([landType])
  @@map("land_agricultural")
  @@schema("public")
}

model BuildingAppraisal {
  id                 String   @id @default(uuid())
  classification     String
  classificationCode String   @map("classification_code")
  buildingType       String   @map("building_type")
  buildingSubClass   String?  @map("building_subclass")
  rate               Decimal  @db.Decimal(12, 2)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @map("updated_at")

  @@map("building_appraisals")
  @@schema("public")
}

model FaasRecord {
  id        String   @id @default(uuid())
  tdn       String?  @unique
  status    String   @default("draft") // draft, for-review, approved
  data      Json
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faas_records")
  @@schema("public")
}

model MigrationLog {
  id        Int      @id @default(autoincrement())
  sourceId  String   @map("source_id") // TDN or ID from MSSQL
  targetId  String   @map("target_id") // ID in Supabase FaasRecord
  status    String   @default("synced")
  timestamp DateTime @default(now())
  details   Json?

  @@index([sourceId])
  @@map("migration_logs")
  @@schema("public")
}

model IdempotencyKey {
  key            String    @id
  userId         String?   @map("user_id")
  path           String
  method         String
  params         Json?
  body           Json?
  responseStatus Int?      @map("response_status")
  responseBody   Json?     @map("response_body")
  createdAt      DateTime  @default(now()) @map("created_at")
  lockedAt       DateTime? @map("locked_at")
  expiresAt      DateTime  @map("expires_at")

  @@map("idempotency_keys")
  @@schema("public")
}

model SidebarItem {
  id        String   @id @default(uuid()) @db.Uuid
  label     String
  path      String
  icon      String?
  parentId  String?  @map("parent_id") @db.Uuid
  order     Int      @default(0)
  adminOnly Boolean  @default(false) @map("admin_only")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent    SidebarItem?                @relation("SidebarHierarchy", fields: [parentId], references: [id])
  children  SidebarItem[]               @relation("SidebarHierarchy")
  visibleTo SidebarItemUserVisibility[]

  @@map("sidebar_items")
  @@schema("public")
}

model SidebarItemUserVisibility {
  sidebarItemId String   @map("sidebar_item_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  sidebarItem SidebarItem @relation(fields: [sidebarItemId], references: [id], onDelete: Cascade)

  @@id([sidebarItemId, userId])
  @@index([userId])
  @@map("sidebar_item_user_visibility")
  @@schema("public")
}

model Payor {
  id        String   @id @default(uuid()) @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  address   String
  idType    String   @map("id_type")
  idNumber  String   @map("id_number")
  contact   Json
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([idType, idNumber], map: "payors_id_type_id_number_key")
  @@index([lastName, firstName])
  @@map("payors")
  @@schema("public")
}
